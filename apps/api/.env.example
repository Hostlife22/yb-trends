# ── App ──────────────────────────────────────────────
YBT_APP_NAME="YB Trends"
YBT_DEFAULT_REGION=US
YBT_DEFAULT_PERIOD=7d
YBT_DEFAULT_LIMIT=20

# ── Provider (mock | pytrends | managed) ────────────
YBT_GOOGLE_PROVIDER=mock
YBT_MANAGED_PROVIDER_URL=
YBT_MANAGED_PROVIDER_API_KEY=

# ── LLM Classifier ─────────────────────────────────
YBT_GEMINI_API_KEY=
# Default: gemini-2.5-flash (supports google_search grounding, wide quota)
YBT_GEMINI_MODEL=gemini-2.5-flash

# ── Security ────────────────────────────────────────
YBT_API_KEY=

# ── Storage ─────────────────────────────────────────
YBT_SQLITE_PATH=.data/trends.db
YBT_CACHE_TTL_SECONDS=600

# ── Sync ────────────────────────────────────────────
YBT_SYNC_INTERVAL_SECONDS=21600
YBT_MAX_SNAPSHOT_AGE_SECONDS=43200
YBT_LOCK_TTL_SECONDS=1200

# ── Quality Gate ────────────────────────────────────
YBT_QUALITY_MIN_ITEMS=5
YBT_QUALITY_MIN_RELEVANT_RATIO=0.2

# ── Alerts ──────────────────────────────────────────
YBT_ALERT_SNAPSHOT_AGE_SECONDS=21600
YBT_ALERT_QUALITY_FAILURES_24H=3

# ── Scheduler ───────────────────────────────────────
YBT_ENABLE_INPROCESS_SCHEDULER=false

# ── Enrichers ───────────────────────────────────────
# Metadata provider: noop | tmdb
YBT_METADATA_PROVIDER=noop
# TMDB v4 Read Access Token (Bearer). Preferred over the v3 API key.
YBT_TMDB_READ_ACCESS_TOKEN=
# TMDB v3 API key (used as fallback if Read Access Token is missing)
YBT_TMDB_API_KEY=

# YouTube stats provider: noop | youtube_api  (Phase 3)
YBT_YOUTUBE_STATS_PROVIDER=noop
YBT_YOUTUBE_API_KEY=

# Composite final_score weights — should roughly sum to 1.0
YBT_SCORE_WEIGHT_SEARCH_DEMAND=0.30
YBT_SCORE_WEIGHT_SEARCH_MOMENTUM=0.20
YBT_SCORE_WEIGHT_YOUTUBE_DEMAND=0.30
YBT_SCORE_WEIGHT_YOUTUBE_FRESHNESS=0.20
